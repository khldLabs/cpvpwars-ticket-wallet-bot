# ─── Bot Credentials ────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here
GUILD_ID=your_server_id_here

# ─── IDs (right-click in Discord with Developer Mode on → Copy ID) ──
# The role whose members can run staff commands (add / use / remove / set / check / history)
STAFF_ROLE_ID=123456789012345678

# The channel where all ticket actions are logged
LOG_CHANNEL_ID=123456789012345678

# ─── Tebex Webhook ───────────────────────────────────────────────────
# Found in: Tebex Control Panel → Integrations → Webhooks → your endpoint → Secret
# The webhook server WILL NOT START if this is missing.
TEBEX_WEBHOOK_SECRET=your_tebex_webhook_secret_here

# Port the webhook HTTP server listens on (default: 3000)
WEBHOOK_PORT=3000
